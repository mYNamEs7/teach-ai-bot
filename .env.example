# Telegram Bot Token (обязательно)
BOT_TOKEN=1234567890:ABCdefGHIjklmNOPqrstUVwxyz

# База данных
# Для Docker: postgresql+asyncpg://teach_ai:teach_ai_pass@localhost:5432/teach_ai_bot
# Для Railway: берётся из переменной DATABASE_URL от Railway Postgres
DATABASE_URL=postgresql+asyncpg://teach_ai:teach_ai_pass@localhost:5432/teach_ai_bot

# Redis
# Для Docker: redis://localhost:6379/0
# Для Railway: берётся из переменной REDIS_URL от Railway Redis
REDIS_URL=redis://localhost:6379/0

# OpenRouter API Key (обязательно)
OPENROUTER_API_KEY=sk-or-v1-ваш_ключ_здесь

# Telegram Payments (оставьте пустым, если пока не настроили)
PAYMENT_PROVIDER_TOKEN=
PAYMENT_STARS_TOKEN=

# ID администраторов (через запятую, без пробелов)
ADMIN_IDS=[123456789]

# Логин и пароль для входа в админ-панель (/admin)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123

# Лимит бесплатных запросов в день
FREE_DAILY_LIMIT=5

# Цены подписок
MONTHLY_PRICE_STARS=50
MONTHLY_PRICE_RUB=199
THREE_MONTH_PRICE_STARS=120
THREE_MONTH_PRICE_RUB=499

# Настройки Redis
REDIS_CONTEXT_MAX=20
REDIS_CLEANUP_DAYS=30
